<Window x:Class="WorkSpaceLauncherPro.App.Views.SmartLayoutPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorkSpaceLauncherPro.App.ViewModels"
        xmlns:controls="clr-namespace:WorkSpaceLauncherPro.App.Views.Controls"
        Title="Smart Layout Picker" Height="640" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource UiFontFamily}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeadingText}">
                <Run Text="Choose a layout for " />
                <Run Text="{Binding Profile.Name, FallbackValue=this profile}" FontWeight="Bold" />
            </TextBlock>
            <TextBlock Style="{StaticResource SubtitleText}" Margin="0,4,0,0">
                <Run Text="{Binding WindowCount, Mode=OneWay}" />
                <Run Text="  ·  " />
                <Run Text="{Binding MonitorLabel, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
            <Button Style="{StaticResource GhostButton}" Content="🎲 Shuffle hero"
                    Command="{Binding ShuffleCommand}" ToolTip="Add a random hero variant" />
        </StackPanel>

        <!-- Gallery -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Layouts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:LayoutOptionViewModel}">
                        <Border Margin="0,0,12,12" Padding="12" CornerRadius="12" Width="220" Height="200" Cursor="Hand"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                MouseLeftButtonUp="OnCardClick"
                                Tag="{Binding}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <controls:LayoutThumbnail Grid.Row="0" Rects="{Binding Rects}" />
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding IconGlyph}" FontSize="16" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="11"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="30" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Left" Style="{StaticResource SubtitleText}" Text="{Binding StatusText}" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="OnCancelClick" Margin="0,0,8,0" />
                <Button Style="{StaticResource PrimaryButton}" Content="Launch" Click="OnLaunchClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
