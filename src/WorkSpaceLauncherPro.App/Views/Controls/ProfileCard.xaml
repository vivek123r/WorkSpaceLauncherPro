<Button x:Class="WorkSpaceLauncherPro.App.Views.Controls.ProfileCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorkSpaceLauncherPro.App.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:ProfileCardViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="220" Height="120" Margin="0,0,12,12"
        Style="{StaticResource GhostButton}"
        Background="{Binding AccentBrush}"
        Click="OnClick"
        Cursor="Hand">
    <Button.ContextMenu>
        <ContextMenu>
            <MenuItem Header="✏️  Edit" Command="{Binding EditCommand}" />
            <MenuItem Header="🗑  Delete" Command="{Binding DeleteCommand}" />
        </ContextMenu>
    </Button.ContextMenu>
    <Button.Template>
        <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="{Binding IconGlyph}" FontSize="28" Foreground="White" />
                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                               Foreground="White" Margin="0,8,0,2" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#CCFFFFFF"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Button.Template>
</Button>
