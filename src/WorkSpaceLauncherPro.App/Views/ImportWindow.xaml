<Window x:Class="WorkSpaceLauncherPro.App.Views.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import" Height="500" Width="700"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource UiFontFamily}">
    <Grid Margin="20">
        <TextBlock Style="{StaticResource HeadingText}" Text="Import" />
        <TextBlock Style="{StaticResource SubtitleText}" Margin="0,8,0,0"
                   Text="Import from .ps1 or .json — wired in M2." />
    </Grid>
</Window>
