<Window x:Class="WorkSpaceLauncherPro.App.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorkSpaceLauncherPro.App.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Profile Editor" Height="720" Width="920"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource UiFontFamily}">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource SubtitleText}">
            <Setter Property="Margin" Value="0,12,0,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeadingText}"
                       Text="{Binding IsNew, Converter={x:Static vm:BoolToTextConverter.NewOrEdit}}" />
            <TextBlock Style="{StaticResource SubtitleText}" Margin="0,4,0,0"
                       Text="Name it, pick an icon and color, then add the apps that should open together." />
        </StackPanel>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Top fields: name / icon / color -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Name" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Default Layout (optional)" />
                        <TextBox Text="{Binding DefaultLayout, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Hotkey" />
                        <TextBlock Text="{Binding HotkeyDisplay}" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Icon" />
                        <Border Width="56" Height="56" CornerRadius="10" Background="{Binding AccentBrush}">
                            <TextBlock Text="{Binding IconGlyph}" FontSize="30" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding IconPresets}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel MaxWidth="160" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource GhostButton}" Width="32" Height="32" Margin="2"
                                            Content="{Binding}" FontSize="18" Padding="0"
                                            Command="{Binding DataContext.PickIconCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Accent Color" />
                        <Border Width="56" Height="56" CornerRadius="10">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding AccentColor}" />
                            </Border.Background>
                        </Border>
                        <ItemsControl ItemsSource="{Binding AccentPresets}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel MaxWidth="120" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="24" Height="24" Margin="2" Padding="0" Cursor="Hand"
                                            Command="{Binding DataContext.PickAccentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="4">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding}" />
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,16,0,8" Background="{StaticResource BorderBrush}" />

                <!-- Apps list -->
                <TextBlock Style="{StaticResource HeadingText}" Text="Apps" FontSize="16" />
                <TextBlock Style="{StaticResource SubtitleText}" Margin="0,2,0,8"
                           Text="Anything in this list will be launched when the profile fires." />

                <ItemsControl ItemsSource="{Binding Apps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AppRowViewModel}">
                            <Border Margin="0,0,0,6" Padding="10" CornerRadius="8"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Margin="8,0,0,0" Text="{Binding KindLabel}" Opacity="0.6" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Summary}" Opacity="0.75" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource GhostButton}" Content="▲" Width="28" Padding="0"
                                                Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{StaticResource GhostButton}" Content="▼" Width="28" Padding="0"
                                                Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{StaticResource GhostButton}" Content="✕" Width="28" Padding="0" Margin="2,0,0,0"
                                                Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,16,0,8" Background="{StaticResource BorderBrush}" />

                <!-- Add new app -->
                <TextBlock Style="{StaticResource HeadingText}" Text="Add an App" FontSize="16" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Kind" Margin="0,0,12,0" />
                    <ComboBox  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                               ItemsSource="{Binding NewAppKinds}" SelectedItem="{Binding NewAppKind}" />

                    <!-- Browser-only row -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Browser / Profile" Margin="0,0,12,0"
                               Visibility="{Binding NewAppKind, Converter={x:Static vm:StringEqualsConverter.BrowserVis}, FallbackValue=Collapsed}" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding NewAppKind, Converter={x:Static vm:StringEqualsConverter.BrowserVis}, FallbackValue=Collapsed}">
                        <ComboBox Width="120" ItemsSource="{Binding BrowserKinds}" SelectedItem="{Binding NewAppBrowser}" />
                        <ComboBox Width="160" Margin="8,0,0,0" ItemsSource="{Binding BrowserProfileDirs}" SelectedItem="{Binding NewAppProfileDir}" />
                    </StackPanel>

                    <!-- Name + target + args + browse -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Name (optional)" Margin="0,0,12,0" />
                    <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,8,8,0" Text="{Binding NewAppName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox   Grid.Row="2" Grid.Column="2" Margin="0,8,8,0" Text="{Binding NewAppTarget, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource GhostButton}" Content="📂"
                                Visibility="{Binding NewAppKind, Converter={x:Static vm:StringEqualsConverter.ExeVis}, FallbackValue=Collapsed}"
                                Command="{Binding BrowseExeCommand}" ToolTip="Browse for executable" />
                        <Button Style="{StaticResource GhostButton}" Content="📁"
                                Visibility="{Binding NewAppKind, Converter={x:Static vm:StringEqualsConverter.FolderVis}, FallbackValue=Collapsed}"
                                Command="{Binding BrowseFolderCommand}" ToolTip="Browse for folder" Margin="4,0,0,0" />
                        <Button Style="{StaticResource PrimaryButton}" Content="Add" Margin="8,0,0,0" Command="{Binding AddAppCommand}" />
                    </StackPanel>
                    <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource SubtitleText}" Margin="0,4,0,0"
                               Text="Tip: for Browser Profile, target is auto-set to the browser; for URL paste a full https:// link."
                               TextWrapping="Wrap" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="2" Style="{StaticResource SubtitleText}" Margin="0,8,0,0"
                   Text="{Binding StatusText}" />

        <!-- Footer buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="OnCancelClick" Margin="0,0,8,0" />
            <Button Style="{StaticResource PrimaryButton}" Content="Save" Click="OnSaveClick" />
        </StackPanel>
    </Grid>
</Window>
