<Window x:Class="WorkSpaceLauncherPro.App.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorkSpaceLauncherPro.App.ViewModels"
        Title="Profile Editor" Height="720" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource UiFontFamily}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource HeadingText}"
                       Text="{Binding IsNew, Converter={x:Static vm:BoolToTextConverter.NewOrEdit}}" />
            <TextBlock Style="{StaticResource SubtitleText}" Margin="0,4,0,0"
                       Text="Name it, pick an icon and color, then add the apps that should open together." />
        </StackPanel>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Top fields: name + icon + color -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource SubtitleText}" Text="Name" Margin="0,0,0,4" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource SubtitleText}" Text="Default Layout (optional)" Margin="0,12,0,4" FontWeight="SemiBold" />
                        <TextBox Text="{Binding DefaultLayout, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource SubtitleText}" Text="Hotkey" Margin="0,12,0,4" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding HotkeyDisplay}" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource SubtitleText}" Text="Icon" Margin="0,0,0,4" FontWeight="SemiBold" />
                        <Border Width="56" Height="56" CornerRadius="10" Background="{Binding AccentBrush}">
                            <TextBlock Text="{Binding IconGlyph}" FontSize="30" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding IconPresets}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel MaxWidth="160" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource GhostButton}" Width="32" Height="32" Margin="2"
                                            Content="{Binding}" FontSize="18" Padding="0"
                                            Command="{Binding DataContext.PickIconCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SubtitleText}" Text="Accent Color" Margin="0,0,0,4" FontWeight="SemiBold" />
                        <Border Width="56" Height="56" CornerRadius="10">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding AccentColor}" />
                            </Border.Background>
                        </Border>
                        <ItemsControl ItemsSource="{Binding AccentPresets}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel MaxWidth="120" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="24" Height="24" Margin="2" Padding="0" Cursor="Hand"
                                            Command="{Binding DataContext.PickAccentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="4">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding}" />
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,16,0,8" Background="{StaticResource BorderBrush}" />

                <!-- Apps list -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource HeadingText}" Text="Apps" FontSize="16" />
                        <TextBlock Style="{StaticResource SubtitleText}" Margin="0,2,0,0"
                                   Text="Anything in this list will be launched when the profile fires." />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                            Content="🔍 Browse installed apps…"
                            Click="OnOpenAppPicker" />
                </Grid>

                <ItemsControl ItemsSource="{Binding Apps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AppRowViewModel}">
                            <Border Margin="0,0,0,6" Padding="10" CornerRadius="8"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Margin="8,0,0,0" Text="{Binding KindLabel}" Opacity="0.6" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Summary}" Opacity="0.75" FontSize="11"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource GhostButton}" Content="▲" Width="28" Padding="0"
                                                Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{StaticResource GhostButton}" Content="▼" Width="28" Padding="0"
                                                Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{StaticResource GhostButton}" Content="✕" Width="28" Padding="0" Margin="2,0,0,0"
                                                Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="2" Style="{StaticResource SubtitleText}" Margin="0,8,0,0"
                   Text="{Binding StatusText}" />

        <!-- Footer buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="OnCancelClick" Margin="0,0,8,0" />
            <Button Style="{StaticResource PrimaryButton}" Content="Save" Click="OnSaveClick" />
        </StackPanel>
    </Grid>
</Window>
