<Window x:Class="WorkSpaceLauncherPro.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WorkSpaceLauncherPro.App.Views"
        xmlns:vm="clr-namespace:WorkSpaceLauncherPro.App.ViewModels"
        Title="WorkSpace Launcher Pro"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource UiFontFamily}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="16,0,0,0" VerticalAlignment="Center"
                           Style="{StaticResource HeadingText}"
                           Text="🚀 WorkSpace Launcher Pro" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Style="{StaticResource GhostButton}" Content="＋ New" Click="OnAddProfileClick"
                            ToolTip="Create a new workspace profile" Padding="10,0" Margin="0,0,4,0" />
                    <Button Style="{StaticResource GhostButton}" Content="↥ Import" Click="OnOpenImportClick"
                            ToolTip="Import a workspace from a PowerShell script" Padding="10,0" Margin="0,0,4,0" />
                    <Button Style="{StaticResource GhostButton}" Content="—" Click="OnMinimizeClick" Width="40" />
                    <Button Style="{StaticResource GhostButton}" Content="✕" Click="OnCloseClick" Width="40" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <views:LauncherPage Grid.Row="1" x:Name="LauncherPageHost" />

        <!-- Status strip -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" Margin="0,0,12,0" VerticalAlignment="Center"
                           Style="{StaticResource SubtitleText}" Text="{Binding StatusText}" />
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                           Style="{StaticResource SubtitleText}" Text="Ready" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
